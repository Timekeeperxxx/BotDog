# BotDog 前端配置模板
# 复制此文件为 .env 并根据实际情况修改：
#   cp frontend/.env.example frontend/.env   (Linux/Mac)
#   copy frontend\.env.example frontend\.env  (Windows)

# ==================== 后端 API 地址 ====================
# 开发阶段（后端与前端运行在同一台机器）：
VITE_API_BASE_URL=http://localhost:8000

# 如果后端运行在其他机器（如机器狗本体），请改为对应 IP：
# VITE_API_BASE_URL=http://192.168.1.100:8000

# ==================== 视频流配置 ====================
# WHEP 视频流地址（需要 MediaMTX + FFmpeg 才能使用）
# 无需视频流功能时可留空，界面仍可正常显示遥测数据
VITE_WHEP_URL=http://localhost:8889/cam/whep

# 如果 MediaMTX 运行在其他机器：
# VITE_WHEP_URL=http://192.168.1.100:8889/cam/whep

# 视频流分辨率宽度（用于界面标签显示：1920=1080p，1280=720p）
VITE_STREAM_WIDTH=1280
